            <if test="cvEnglish != null">cv_english = #{cvEnglish},</if>
            <if test="cvJapanese != null">cv_japanese = #{cvJapanese},</if>
            <if test="cvKorean != null">cv_korean = #{cvKorean},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteGenshinCharacterById" parameterType="Long">
        delete from genshin_character where id = #{id}
    </delete>

    <delete id="deleteGenshinCharacterByIds" parameterType="String">
        delete from genshin_character where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>