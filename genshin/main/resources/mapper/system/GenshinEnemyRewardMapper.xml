<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.GenshinEnemyRewardMapper">
    
    <resultMap type="GenshinEnemyReward" id="GenshinEnemyRewardResult">
        <result property="id"    column="id"    />
        <result property="enemyId"    column="enemy_id"    />
        <result property="itemId"    column="item_id"    />
        <result property="itemName"    column="item_name"    />
        <result property="itemCount"    column="item_count"    />
        <result property="itemRarity"    column="item_rarity"    />
    </resultMap>

    <sql id="selectGenshinEnemyRewardVo">
        select id, enemy_id, item_id, item_name, item_count, item_rarity from genshin_enemy_reward
    </sql>

    <select id="selectGenshinEnemyRewardList" parameterType="GenshinEnemyReward" resultMap="GenshinEnemyRewardResult">
        <include refid="selectGenshinEnemyRewardVo"/>
        <where>  
            <if test="enemyId != null "> and enemy_id = #{enemyId}</if>
            <if test="itemId != null "> and item_id = #{itemId}</if>
            <if test="itemName != null  and itemName != ''"> and item_name like concat('%', #{itemName}, '%')</if>
            <if test="itemCount != null "> and item_count = #{itemCount}</if>
            <if test="itemRarity != null "> and item_rarity = #{itemRarity}</if>
        </where>
    </select>
    
    <select id="selectGenshinEnemyRewardById" parameterType="Long" resultMap="GenshinEnemyRewardResult">
        <include refid="selectGenshinEnemyRewardVo"/>
        where id = #{id}
    </select>

    <insert id="insertGenshinEnemyReward" parameterType="GenshinEnemyReward" useGeneratedKeys="true" keyProperty="id">
        insert into genshin_enemy_reward
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="enemyId != null">enemy_id,</if>
            <if test="itemId != null">item_id,</if>
            <if test="itemName != null and itemName != ''">item_name,</if>
            <if test="itemCount != null">item_count,</if>
            <if test="itemRarity != null">item_rarity,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="enemyId != null">#{enemyId},</if>
            <if test="itemId != null">#{itemId},</if>
            <if test="itemName != null and itemName != ''">#{itemName},</if>
            <if test="itemCount != null">#{itemCount},</if>
            <if test="itemRarity != null">#{itemRarity},</if>
         </trim>
    </insert>

    <update id="updateGenshinEnemyReward" parameterType="GenshinEnemyReward">
        update genshin_enemy_reward
        <trim prefix="SET" suffixOverrides=",">
            <if test="enemyId != null">enemy_id = #{enemyId},</if>
            <if test="itemId != null">item_id = #{itemId},</if>
            <if test="itemName != null and itemName != ''">item_name = #{itemName},</if>
            <if test="itemCount != null">item_count = #{itemCount},</if>
            <if test="itemRarity != null">item_rarity = #{itemRarity},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteGenshinEnemyRewardById" parameterType="Long">
        delete from genshin_enemy_reward where id = #{id}
    </delete>

    <delete id="deleteGenshinEnemyRewardByIds" parameterType="String">
        delete from genshin_enemy_reward where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>