<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.GenshinUserFavoriteMapper">
    
    <resultMap type="GenshinUserFavorite" id="GenshinUserFavoriteResult">
        <result property="id"    column="id"    />
        <result property="userId"    column="user_id"    />
        <result property="targetType"    column="target_type"    />
        <result property="targetId"    column="target_id"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectGenshinUserFavoriteVo">
        select id, user_id, target_type, target_id, create_time from genshin_user_favorite
    </sql>

    <select id="selectGenshinUserFavoriteList" parameterType="GenshinUserFavorite" resultMap="GenshinUserFavoriteResult">
        <include refid="selectGenshinUserFavoriteVo"/>
        <where>  
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="targetType != null  and targetType != ''"> and target_type = #{targetType}</if>
            <if test="targetId != null "> and target_id = #{targetId}</if>
        </where>
    </select>
    
    <select id="selectGenshinUserFavoriteById" parameterType="Long" resultMap="GenshinUserFavoriteResult">
        <include refid="selectGenshinUserFavoriteVo"/>
        where id = #{id}
    </select>

    <insert id="insertGenshinUserFavorite" parameterType="GenshinUserFavorite" useGeneratedKeys="true" keyProperty="id">
        insert into genshin_user_favorite
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="targetType != null">target_type,</if>
            <if test="targetId != null">target_id,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="targetType != null">#{targetType},</if>
            <if test="targetId != null">#{targetId},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateGenshinUserFavorite" parameterType="GenshinUserFavorite">
        update genshin_user_favorite
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="targetType != null">target_type = #{targetType},</if>
            <if test="targetId != null">target_id = #{targetId},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteGenshinUserFavoriteById" parameterType="Long">
        delete from genshin_user_favorite where id = #{id}
    </delete>

    <delete id="deleteGenshinUserFavoriteByIds" parameterType="String">
        delete from genshin_user_favorite where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>